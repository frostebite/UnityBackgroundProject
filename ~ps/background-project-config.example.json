{
    "// INSTRUCTIONS": "Copy this file to 'background-project-config.json' (same folder) and customize for your project.",
    "// artifactSubpath": "The company/product subfolder under AppData/LocalLow where Unity writes test results.",
    "// buildMethodMap": "Maps framework IDs to C# build methods. Each entry needs 'validation' and 'steam' variants.",
    "// primaryInstance": "Editor-side tools continue using this instance as the legacy single background project.",
    "// instances": "Define any number of named background project instances. Each instance may also declare githubRunner settings.",

    "artifactSubpath": "My Company/My Game",
    "primaryInstance": "primary",

    "// targetMachines": "Optional array of machine name patterns. Omit or use ['*'] for all machines. Uses PowerShell -like wildcards (* and ?).",

    "instances": [
        {
            "kind": "unity-worker",
            "displayName": "Primary",
            "name": "primary",
            "suffix": "-BackgroundWorker",
            "// targetMachines omitted": "Omitting targetMachines means this instance runs on ALL machines (backward compatible)"
        },
        {
            "kind": "github-runner",
            "displayName": "CI Runner - All Machines",
            "name": "ci-runner-all",
            "targetMachines": ["*"],
            "githubRunner": {
                "enabled": true,
                "repository": "frostebite/GameClient",
                "runnerName": "unity-background-ci",
                "runnerPath": "D:\\actions-runner-unity-background-ci",
                "workspacePath": "D:\\actions-runner-unity-background-ci\\_work\\GameClient\\GameClient",
                "labels": [ "unity", "dynamic", "background" ]
            }
        },
        {
            "kind": "github-runner",
            "displayName": "CI Runner - Specific Machine",
            "name": "ci-runner-desk",
            "targetMachines": ["COOLMASTER-DESK"],
            "githubRunner": {
                "enabled": true,
                "repository": "frostebite/GameClient",
                "runnerName": "unity-background-desk",
                "runnerPath": "D:\\actions-runner-unity-background-desk",
                "workspacePath": "D:\\actions-runner-unity-background-desk\\_work\\GameClient\\GameClient",
                "labels": [ "unity", "dynamic", "background", "desk" ]
            }
        },
        {
            "kind": "github-runner",
            "displayName": "CI Runner - Pattern Match",
            "name": "ci-runner-build",
            "targetMachines": ["BUILD-*"],
            "githubRunner": {
                "enabled": true,
                "repository": "frostebite/GameClient",
                "runnerName": "unity-background-build",
                "runnerPath": "D:\\actions-runner-unity-background-build",
                "workspacePath": "D:\\actions-runner-unity-background-build\\_work\\GameClient\\GameClient",
                "labels": [ "unity", "dynamic", "background", "build-farm" ]
            }
        }
    ],

    "buildMethodMap": {
        "myframework": {
            "validation": "BuildMethodTest.MyFrameworkBuildValidation",
            "steam": "BuildMethodTest.MyFrameworkBuild"
        }
    }
}
